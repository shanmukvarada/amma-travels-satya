{
  "entities": {
    "Vehicle": {
      "title": "Vehicle",
      "description": "A rental vehicle in the platform.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "type": { "type": "string", "enum": ["car", "bike"] },
        "fuelType": { "type": "string", "enum": ["Petrol", "Diesel", "EV", "Hybrid"] },
        "seatingCapacity": { "type": "number" },
        "transmission": { "type": "string", "enum": ["Manual", "Automatic"] },
        "registrationNumber": { "type": "string" },
        "pricePerDay": { "type": "number" },
        "securityDeposit": { "type": "number" },
        "description": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } },
        "images": { "type": "array", "items": { "type": "string" } },
        "isAvailable": { "type": "boolean" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["name", "type", "pricePerDay", "isAvailable", "createdAt", "updatedAt"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A booking request for a vehicle.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "vehicleId": { "type": "string" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected", "active", "returned"] },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "totalCost": { "type": "number" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["userId", "vehicleId", "startDate", "endDate", "status", "customerName", "customerPhone", "totalCost", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/vehicles/{vehicleId}": {
      "schema": { "$ref": "#/entities/Vehicle" },
      "description": "Collection of all vehicles available for rent."
    },
    "/bookings/{bookingId}": {
      "schema": { "$ref": "#/entities/Booking" },
      "description": "Collection of all vehicle bookings."
    },
    "/admins/{adminId}": {
      "schema": { "type": "object", "properties": { "email": { "type": "string" } } },
      "description": "Trusted collection to confer admin privileges based on UID."
    }
  }
}
