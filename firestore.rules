rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global lock
    match /{document=**} { 
      allow read, write: if false; 
    }

    // Auth & Admin Helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'shanmukvarada@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    
    function isValidId(id) { 
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Validation for Bookings
    function isValidBooking(data) {
      return data.keys().hasAll(['userId', 'vehicleId', 'startDate', 'endDate', 'status', 'totalCost', 'customerName', 'customerPhone', 'createdAt', 'updatedAt']) 
        && data.size() == 10
        && data.userId is string && data.userId.size() <= 128
        && data.vehicleId is string && data.vehicleId.size() <= 128
        && data.startDate is string && data.startDate.size() <= 64
        && data.endDate is string && data.endDate.size() <= 64
        && data.status in ['pending', 'approved', 'rejected', 'active', 'returned']
        && data.totalCost is number
        && data.customerName is string && data.customerName.size() <= 100
        && data.customerPhone is string && data.customerPhone.size() <= 20
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    // Vehicles Collection
    match /vehicles/{vehicleId} {
      allow read: if true; 
      allow write: if isAdmin() && isValidId(vehicleId); 
    }

    // Bookings Collection
    match /bookings/{bookingId} {
      allow read: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
      
      // Creating a booking
      allow create: if isSignedIn() 
        && isValidId(bookingId)
        && isValidBooking(incoming())
        && incoming().userId == request.auth.uid
        && incoming().status == 'pending';

      // Admins manage state (approvals, returning)
      allow update: if isAdmin() && isValidId(bookingId) 
        && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']);
        
      allow delete: if isAdmin();
    }

    // Admins metadata
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if false; 
    }
  }
}
